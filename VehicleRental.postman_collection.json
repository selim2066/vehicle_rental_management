{
  "info": {
    "name": "Vehicle Rental System API",
    "description": "Complete API collection for the Vehicle Rental System assignment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "customerToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup (Customer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"01722222222\",\n  \"role\": \"customer\"\n}"
            }
          }
        },
        {
          "name": "Signup (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@vehiclerental.com\",\n  \"password\": \"admin123\",\n  \"phone\": \"01700000000\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Signin (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('adminToken', res.data.token);",
                  "  console.log('Admin token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signin",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@vehiclerental.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Signin (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('customerToken', res.data.token);",
                  "  console.log('Customer token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signin",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"customer123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "Get All Vehicles (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vehicles"
          }
        },
        {
          "name": "Get Vehicle by ID (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vehicles/1"
          }
        },
        {
          "name": "Create Vehicle (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/vehicles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicle_name\": \"Toyota Camry 2023\",\n  \"type\": \"car\",\n  \"registration_number\": \"DHK-CA-2023\",\n  \"daily_rent_price\": 2500,\n  \"availability_status\": \"available\"\n}"
            }
          }
        },
        {
          "name": "Update Vehicle (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/vehicles/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"daily_rent_price\": 3000,\n  \"availability_status\": \"available\"\n}"
            }
          }
        },
        {
          "name": "Delete Vehicle (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/vehicles/1"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Update User (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/users/2",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe Updated\",\n  \"phone\": \"01799999999\"\n}"
            }
          }
        },
        {
          "name": "Update Own Profile (Customer)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/users/2",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"phone\": \"01711111111\"\n}"
            }
          }
        },
        {
          "name": "Delete User (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/users/2"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking (Customer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicle_id\": 1,\n  \"rent_start_date\": \"2025-05-01\",\n  \"rent_end_date\": \"2025-05-05\"\n}"
            }
          }
        },
        {
          "name": "Get All Bookings (Admin - sees all)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Get My Bookings (Customer - own only)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Cancel Booking (Customer)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/bookings/1"
          }
        },
        {
          "name": "Return Booking (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/bookings/1"
          }
        }
      ]
    }
  ]
}
