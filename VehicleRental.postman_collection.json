{
  "info": {
    "name": "Vehicle Rental System V2 API",
    "description": "Complete API collection for the Premium Vehicle Rental System with Prisma and extended modules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "customerToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup (Customer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Selim Reza\",\n  \"email\": \"selim@example.com\",\n  \"password\": \"selim123\",\n  \"phone\": \"01707453950\",\n  \"role\": \"customer\"\n}"
            }
          }
        },
        {
          "name": "Signin (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('adminToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('Admin tokens saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signin",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@vehiclerental.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Signin (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('customerToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('Customer tokens saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signin",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"selim@example.com\",\n  \"password\": \"selim123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Signout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "Get All Vehicles (with Filters)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/vehicles?type=car&brand=Toyota&minPrice=1000&maxPrice=5000&sort=price_asc",
              "host": ["{{baseUrl}}"],
              "path": ["vehicles"],
              "query": [
                { "key": "type", "value": "car" },
                { "key": "brand", "value": "Toyota" },
                { "key": "minPrice", "value": "1000" },
                { "key": "maxPrice", "value": "5000" },
                { "key": "sort", "value": "price_asc" }
              ]
            }
          }
        },
        {
          "name": "Get Featured Vehicles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vehicles/featured"
          }
        },
        {
          "name": "Get Vehicle Details (with Images/Features)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vehicles/1"
          }
        },
        {
          "name": "Get Related Vehicles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vehicles/1/related"
          }
        },
        {
          "name": "Create Vehicle (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/vehicles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicle_name\": \"Tesla Model 3 2024\",\n  \"type\": \"car\",\n  \"brand\": \"Tesla\",\n  \"model\": \"Model 3\",\n  \"year\": 2024,\n  \"registration_number\": \"DHK-EV-2024\",\n  \"daily_rent_price\": 8000,\n  \"availability_status\": \"available\",\n  \"fuel_type\": \"electric\",\n  \"transmission\": \"automatic\",\n  \"seats\": 5,\n  \"is_featured\": true,\n  \"images\": [\"https://example.com/tesla.jpg\"],\n  \"features\": [\"Autopilot\", \"Glass Roof\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Vroom vroom!\",\n  \"address\": \"Dhaka, Bangladesh\"\n}"
            }
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/users"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicle_id\": 1,\n  \"rent_start_date\": \"2025-06-01\",\n  \"rent_end_date\": \"2025-06-05\"\n}"
            }
          }
        },
        {
          "name": "Get All Bookings (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/bookings"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Submit Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "url": "{{baseUrl}}/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicle_id\": 1,\n  \"rating\": 5,\n  \"comment\": \"Excellent car, very smooth!\"\n}"
            }
          }
        },
        {
          "name": "Get Vehicle Reviews",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reviews/vehicle/1"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Admin Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/dashboard/stats"
          }
        },
        {
          "name": "Get Revenue Chart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/dashboard/revenue"
          }
        }
      ]
    },
    {
      "name": "Newsletter",
      "item": [
        {
          "name": "Subscribe",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/newsletter/subscribe",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            }
          }
        }
      ]
    }
  ]
}
